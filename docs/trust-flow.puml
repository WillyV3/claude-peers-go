@startuml Trust Flow
!theme cyborg
skinparam backgroundColor #0B0C16
skinparam defaultFontColor #ddf7ff
skinparam defaultFontName "Monaspace Krypton"
skinparam sequenceArrowColor #6a6e95
skinparam sequenceLifeLineBorderColor #1a1c30
skinparam sequenceParticipantBorderColor #1a1c30
skinparam sequenceParticipantBackgroundColor #0f1019
skinparam sequenceDividerBackgroundColor #1a1c30

title <color:#82FB9C><b>TRUST FLOW</b></color>\n<color:#6a6e95>From request to enforcement</color>

participant "Claude Code\nSession" as client #0f1019
participant "Trust\nBroker" as broker #0f1019
participant "UCAN\nValidator" as ucan #0f1019
participant "Health\nChecker" as health #0f1019
participant "NATS" as nats #0f1019
participant "Wazuh\nBridge" as wazuh #0f1019

== Normal Request ==

client -> broker : POST /list-peers\nAuthorization: Bearer <jwt>
broker -> ucan : Validate(token)
ucan -> ucan : Verify Ed25519 signature
ucan -> ucan : Check expiry (30s leeway)
ucan -> ucan : Verify delegation chain (prf)
ucan -> ucan : Check capability: peer/list
ucan --> broker : <color:#82FB9C>Claims valid</color>
broker -> health : getMachineHealth(machine)
health --> broker : <color:#82FB9C>status: healthy</color>
broker --> client : <color:#82FB9C>200 OK</color> [peer list]

== Security Event ==

wazuh -> nats : <color:#ff6b6b>fleet.security.fim</color>\nlevel=12 (UCAN credential modified)
nats -> broker : SecurityEvent
broker -> health : updateMachineHealth(+10)
health -> health : score=10 -> <color:#ff6b6b>quarantined</color>

== Quarantined Request ==

client -> broker : POST /send-message\nAuthorization: Bearer <jwt>
broker -> ucan : Validate(token)
ucan --> broker : <color:#82FB9C>Claims valid</color>
broker -> health : getMachineHealth(machine)
health --> broker : <color:#ff6b6b>status: quarantined</color>
broker --> client : <color:#ff6b6b>403 QUARANTINED</color>

== Recovery ==

actor Operator
Operator -> broker : POST /unquarantine\n{"machine": "compromised-host"}
broker -> health : reset score=0, status=healthy
broker --> Operator : <color:#82FB9C>200 OK</color>

@enduml
